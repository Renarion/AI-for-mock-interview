# Copy to backend/.env, оригинал лежит на серевере, это просто пример как его заполнять

# Database connection (Docker: hostname "db")
DATABASE_URL=postgresql+asyncpg://postgres@db:5432/mock_interview

# JWT secret (required for auth)
SECRET_KEY=

# Frontend URL (used for CORS)
FRONTEND_URL=

# DEBUG=false in production
DEBUG=false

# LLM: только OpenAI; модель/промпт — в app/llm_config.yaml (см. KEYS_SETUP_GUIDE.md, LLM_QUICKSTART.md)
OPENAI_API_KEY=
# OpenAI-compatible API (по умолчанию в llm_config.yaml — api.vsellm.ru). Переопределение:
# OPENAI_BASE_URL=https://api.vsellm.ru/v1

# YooKassa (see KEYS_SETUP_GUIDE.md)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
